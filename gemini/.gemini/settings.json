{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "hasSeenIdeIntegrationNudge": true,
  "ide": {
    "enabled": true
  },
  "mcpServers": {
    "local-excel": {
      "command": "uvx",
      "args": [
        "excel-mcp-server",
        "stdio"
      ],
      "env": {
        "EXCEL_FILES_PATH": "/Users/minh/gitrepos"
      }
    },
    "rtfm": {
      "command": "rtfm-serve",
      "args": [],
      "env": {
        "RTFM_ROOT": "/Users/minh/gitrepos"
      }
    },
    "code-review-graph": {
      "command": "uvx",
      "args": [
        "code-review-graph",
        "serve"
      ]
    },
    "google-workspace": {
      "httpUrl": "http://0.0.0.0:8000/mcp"
    }
  },
  "ui": {
    "theme": "Default Light",
    "footer": {
      "items": [
        "workspace",
        "git-branch",
        "sandbox",
        "model-name",
        "quota",
        "memory-usage",
        "context-used",
        "token-count"
      ]
    }
  },
  "general": {
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d",
      "warningAcknowledged": true
    }
  }
}
