{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "hasSeenIdeIntegrationNudge": true,
  "ide": {
    "enabled": true
  },
  "mcpServers": {
    "local-excel": {
      "command": "uvx",
      "args": [
        "excel-mcp-server",
        "stdio"
      ],
      "env": {
        "EXCEL_FILES_PATH": "/Users/minh/gitrepos"
      }
    },
    "rtfm": {
      "command": "rtfm-serve",
      "args": [],
      "env": {
        "RTFM_DB": ".rtfm/library.db"
      }
    },
    "code-review-graph": {
      "command": "uvx",
      "args": ["code-review-graph", "serve"]
    }
  },
  "ui": {
    "theme": "Default Light"
  },
  "general": {
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d",
      "warningAcknowledged": true
    }
  }
}
